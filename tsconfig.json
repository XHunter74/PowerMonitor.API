{
    "compilerOptions": {
        "module": "commonjs",
        "skipLibCheck": true,
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "target": "es6",
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "incremental": true
    },
    "exclude": [
        "node_modules"
    ]
}